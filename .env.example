# Solana Configuration
SOLANA_NETWORK=devnet
# Options: devnet, mainnet-beta, localhost

# RPC Endpoint (optional - defaults to public RPC)
# For production, use a premium RPC provider
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID (update after deployment)
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Wallet Configuration
# Path to deployer keypair (for deployment only)
ANCHOR_WALLET=~/.config/solana/id.json

# Mobile App Configuration (for mobile/.env)
# EXPO_PUBLIC_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
# EXPO_PUBLIC_CLUSTER=devnet
# EXPO_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# Monitoring (optional)
# DATADOG_API_KEY=your_api_key
# SENTRY_DSN=your_sentry_dsn

# Security
# Never commit real private keys or seed phrases!
# Use environment variables or secure key management systems
